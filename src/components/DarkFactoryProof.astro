---
// DarkFactoryProof.astro
// The Sovereign Council — framed as a live operational system, not a concept
---

<section
  class="relative py-24 lg:py-32 overflow-hidden bg-slate-900/40"
  aria-label="Dark Factory Proof"
>
  <!-- Top edge -->
  <div class="absolute top-0 left-0 right-0 h-px bg-gold-edge"></div>
  <!-- Bottom edge -->
  <div class="absolute bottom-0 left-0 right-0 h-px bg-gold-edge"></div>

  <!-- Background glow -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 60% 40% at 50% 50%, rgba(212,175,55,0.04) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <!-- Header -->
    <div class="grid lg:grid-cols-12 gap-8 mb-16">
      <div class="lg:col-span-3">
        <span class="section-label">Live System</span>
        <div class="mt-3 w-12 h-px bg-gold/40"></div>
      </div>
      <div class="lg:col-span-9">
        <div class="flex items-start gap-4">
          <div>
            <!-- Live indicator -->
            <div class="flex items-center gap-2 mb-4">
              <span class="inline-flex items-center gap-1.5 font-mono text-xs text-emerald-400/80 tracking-wider">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse inline-block"></span>
                OPERATIONAL — DARK FACTORY v1.0
              </span>
            </div>
            <h2
              class="font-heading font-700 text-slate-100 leading-tight mb-4"
              style="font-size: clamp(1.75rem, 3.5vw, 3rem); letter-spacing: -0.02em;"
            >
              The Sovereign Council
            </h2>
            <p class="font-body text-slate-400 max-w-2xl" style="font-size: 1.0625rem; line-height: 1.75;">
              A live, production-deployed multi-agent AI architecture. Thirteen
              specialized agents operating across five operational domains.
              This is not a portfolio project. It is my primary business
              infrastructure — running continuously, executing across strategy,
              legal, venture, finance, and build execution with zero human
              operator touchpoints between task and delivery.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Agent grid -->
    <div class="grid lg:grid-cols-12 gap-8 items-start">
      <div class="lg:col-span-3"></div>
      <div class="lg:col-span-9">

        <!-- Domain tiles -->
        <div class="space-y-3">
          {
            [
              {
                tier: "T1",
                label: "Executive Command",
                agents: ["METATRON — Principal Architect & Systems Orchestrator"],
                color: "gold",
              },
              {
                tier: "T2",
                label: "Strategic Intelligence",
                agents: [
                  "The Career Architect — W2 trajectory & positioning",
                  "The Venture Architect — GWI & CMBS strategy",
                  "The Legal Guardian — IP, contracts, compliance",
                  "The Wealth Intelligence System — financial intelligence",
                ],
                color: "cyber",
              },
              {
                tier: "T3",
                label: "Execution Layer",
                agents: [
                  "The Sovereign Design Studio — digital build & infrastructure",
                  "The GrowthWave Forge — content & brand media",
                  "The Talent Engine — recruiting & team build",
                ],
                color: "slate",
              },
            ].map((domain) => (
              <div
                class="border border-white/5 p-5 hover:border-gold/20 transition-all duration-300 group"
              >
                <div class="flex items-start gap-4">
                  <!-- Tier badge -->
                  <div
                    class:list={[
                      "shrink-0 font-mono text-xs px-2 py-1 tracking-widest",
                      domain.color === "gold"
                        ? "border border-gold/40 text-gold/80"
                        : domain.color === "cyber"
                          ? "border border-cyber/30 text-cyber/70"
                          : "border border-slate-700 text-slate-500",
                    ]}
                  >
                    {domain.tier}
                  </div>

                  <div class="flex-1 min-w-0">
                    <div class="font-heading font-600 text-xs tracking-[0.15em] uppercase text-slate-400 mb-2">
                      {domain.label}
                    </div>
                    <div class="space-y-1">
                      {domain.agents.map((agent) => (
                        <div class="flex items-start gap-2">
                          <span class="text-gold/30 mt-0.5 shrink-0">▸</span>
                          <span class="font-mono text-xs text-slate-400 group-hover:text-slate-300 transition-colors duration-200">
                            {agent}
                          </span>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <!-- Proof metrics -->
        <div class="mt-8 grid grid-cols-3 gap-4">
          {
            [
              { value: "13", label: "Specialized agents" },
              { value: "5", label: "Operational domains" },
              { value: "0", label: "Human operator touchpoints" },
            ].map((m) => (
              <div class="border border-gold/10 p-4 text-center">
                <div class="font-heading font-800 text-gold" style="font-size: 1.75rem;">
                  {m.value}
                </div>
                <div class="font-mono text-xs text-slate-600 mt-1 tracking-wide">
                  {m.label}
                </div>
              </div>
            ))
          }
        </div>

        <!-- Link to work -->
        <div class="mt-6">
          <a
            href="/work"
            class="inline-flex items-center gap-2 font-heading text-xs tracking-[0.15em] uppercase text-gold/70 hover:text-gold transition-colors duration-200"
          >
            View full architecture documentation
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
