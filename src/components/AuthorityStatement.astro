---
// AuthorityStatement.astro
// What Wilfred builds and why it matters to the visitor
import homepageData from "../data/homepage.json";
const { authorityStatement } = homepageData;
const headlineParts = authorityStatement.headline.split(authorityStatement.headlineHighlight);
const p2parts = authorityStatement.paragraphs[1].split(authorityStatement.flagshipHighlight);
---

<section
  class="relative py-24 lg:py-32 overflow-hidden"
  aria-label="Authority Statement"
>
  <!-- Decorative right edge line -->
  <div
    class="absolute right-6 lg:right-12 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-cyber/15 to-transparent"
    aria-hidden="true"
  ></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-start">

      <!-- Left: label column -->
      <div class="lg:col-span-3">
        <div class="sticky top-24">
          <span class="section-label">{authorityStatement.sectionLabel}</span>
          <div class="mt-3 w-12 h-px bg-gold/40"></div>
        </div>
      </div>

      <!-- Right: content -->
      <div class="lg:col-span-9">

        <!-- Lead statement -->
        <h2
          class="font-heading font-bold text-slate-100 mb-8 leading-tight"
          style="font-size: clamp(1.75rem, 3.5vw, 3rem); letter-spacing: -0.02em;"
        >
          {headlineParts[0]}<span class="text-gradient-gold">{authorityStatement.headlineHighlight}</span>{headlineParts[1]}
        </h2>

        <!-- Body paragraphs -->
        <div class="space-y-6 font-body text-slate-400" style="font-size: 1.0625rem; line-height: 1.75;">
          {authorityStatement.paragraphs.map((para, idx) =>
            idx === 1 ? (
              <p>
                {p2parts[0]}<span class="text-slate-200 font-semibold">{authorityStatement.flagshipHighlight}</span>{p2parts[1]}
              </p>
            ) : (
              <p>{para}</p>
            )
          )}
        </div>

        <!-- Capability cards -->
        <div class="mt-12 grid sm:grid-cols-2 gap-4">
          {
            authorityStatement.capabilities.map((cap) => (
              <div class="gold-border-hover p-6 group">
                <div class="text-gold font-mono text-xl mb-3 group-hover:text-gold transition-colors duration-200">
                  {cap.icon}
                </div>
                <h3 class="font-heading font-semibold text-slate-100 text-sm tracking-wide mb-2">
                  {cap.title}
                </h3>
                <p class="font-body text-slate-500 text-sm leading-relaxed">
                  {cap.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
