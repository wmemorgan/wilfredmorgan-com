---
import { SITE } from "../consts/index";

const { pathname } = Astro.url;

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
  data-scrolled="false"
>
  <!-- Gold top border -->
  <div class="h-px bg-gradient-to-r from-transparent via-gold/60 to-transparent"></div>

  <nav
    class="mx-auto max-w-7xl px-6 lg:px-8 flex items-center justify-between h-16"
  >
    <!-- Logo / Wordmark -->
    <a
      href="/"
      class="font-heading font-700 text-slate-100 tracking-tight group flex items-center gap-2"
      aria-label="Wilfred Morgan — Home"
    >
      <!-- Monogram mark -->
      <span
        class="inline-flex items-center justify-center w-8 h-8 border border-gold/40 text-gold font-mono text-xs font-700 group-hover:border-gold/80 group-hover:bg-gold/5 transition-all duration-200"
      >
        WM
      </span>
      <span class="hidden sm:block text-sm tracking-[0.12em] uppercase text-slate-200 group-hover:text-gold transition-colors duration-200">
        Wilfred Morgan
      </span>
    </a>

    <!-- Desktop nav links -->
    <ul class="hidden md:flex items-center gap-8">
      {
        SITE.navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "font-heading text-xs tracking-[0.2em] uppercase transition-all duration-200",
                isActive(link.href)
                  ? "text-gold"
                  : "text-slate-400 hover:text-slate-100",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA button -->
    <div class="hidden md:block">
      <a href="/contact" class="btn-ghost text-xs py-2 px-4">
        Book a Call
      </a>
    </div>

    <!-- Mobile menu toggle -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2 group"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="block w-5 h-px bg-slate-400 group-hover:bg-gold transition-colors duration-200"></span>
      <span class="block w-5 h-px bg-slate-400 group-hover:bg-gold transition-colors duration-200"></span>
      <span class="block w-3 h-px bg-slate-400 group-hover:bg-gold transition-colors duration-200"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden border-t border-gold/10 bg-obsidian/98 backdrop-blur-md"
  >
    <ul class="px-6 py-6 flex flex-col gap-6">
      {
        SITE.navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "font-heading text-sm tracking-[0.2em] uppercase",
                isActive(link.href) ? "text-gold" : "text-slate-300",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="pt-2">
        <a href="/contact" class="btn-ghost text-xs">Book a Call</a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Scroll behavior — add background on scroll
  const header = document.getElementById("site-header");
  const toggle = document.getElementById("mobile-menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      header?.classList.add("bg-obsidian/95", "backdrop-blur-md", "shadow-lg", "shadow-black/20");
      header?.setAttribute("data-scrolled", "true");
    } else {
      header?.classList.remove("bg-obsidian/95", "backdrop-blur-md", "shadow-lg", "shadow-black/20");
      header?.setAttribute("data-scrolled", "false");
    }
  });

  // Mobile menu
  toggle?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.contains("hidden");
    mobileMenu?.classList.toggle("hidden", !isOpen);
    toggle?.setAttribute("aria-expanded", isOpen ? "true" : "false");
  });
</script>
