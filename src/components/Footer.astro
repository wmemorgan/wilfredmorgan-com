---
import { SITE } from "../consts/index";

const year = new Date().getFullYear();
---

<footer class="relative border-t border-gold/10 bg-obsidian">
  <!-- Gold top line -->
  <div class="h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-8 py-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">

      <!-- Left: Wordmark + tagline -->
      <div class="flex flex-col gap-2">
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center justify-center w-8 h-8">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120" class="w-full h-full" aria-hidden="true">
              <path d="M 8 20 L 8 100 L 20 100 L 20 20 Z" fill="#D4AF37"/>
              <path d="M 20 100 L 30 48 L 40 100 Z" fill="#D4AF37"/>
              <path d="M 40 20 L 40 100 L 52 100 L 52 20 Z" fill="#D4AF37"/>
              <path d="M 60 20 L 60 100 L 72 100 L 72 20 Z" fill="#D4AF37"/>
              <path d="M 72 20 L 82 60 L 92 20 Z" fill="#D4AF37" opacity="0.5"/>
              <path d="M 92 20 L 92 100 L 104 100 L 104 20 Z" fill="#D4AF37"/>
            </svg>
          </span>
          <span class="font-heading text-xs tracking-[0.2em] uppercase text-slate-400">
            Wilfred Morgan
          </span>
        </div>
        <p class="font-mono text-xs text-slate-400 tracking-wider">
          Enterprise AI Architect · Agentic AI Implementation
        </p>
      </div>

      <!-- Center: Nav -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-6">
          <li>
            <a href="/work" class="font-heading text-xs tracking-[0.15em] uppercase text-slate-400 hover:text-gold transition-colors duration-200">
              Enterprise AI Case Studies
            </a>
          </li>
          <li>
            <a href="/writing" class="font-heading text-xs tracking-[0.15em] uppercase text-slate-400 hover:text-gold transition-colors duration-200">
              AI Architecture Blog
            </a>
          </li>
          <li>
            <a href="/about" class="font-heading text-xs tracking-[0.15em] uppercase text-slate-400 hover:text-gold transition-colors duration-200">
              About Wilfred Morgan
            </a>
          </li>
          <li>
            <a href="/contact" class="font-heading text-xs tracking-[0.15em] uppercase text-slate-400 hover:text-gold transition-colors duration-200">
              Book an AI Strategy Call
            </a>
          </li>
        </ul>
      </nav>

      <!-- Right: CTA -->
      <a href="/contact" class="btn-ghost text-xs py-2 px-4 shrink-0">
        Book a Call →
      </a>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-mono text-xs text-slate-500">
        © {year} Wilfred Morgan. All rights reserved.
      </p>
      <div class="flex items-center gap-1">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-gold/40 animate-pulse"></span>
        <span class="font-mono text-xs text-slate-500">Dark Factory · Sovereign Council</span>
      </div>
    </div>
  </div>
</footer>
