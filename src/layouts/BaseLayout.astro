---
import "../styles/global.css";
import { SITE } from "../consts/index";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  ogType?: string;
  extraJsonLd?: Record<string, any>[];
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage = SITE.ogImage,
  noIndex = false,
  ogType = "website",
  extraJsonLd = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex ? <meta name="robots" content="noindex,nofollow" /> : <meta name="robots" content="index,follow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <meta name="generator" content={Astro.generator} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Wilfred Morgan",
      "url": "https://wilfredmorgan.com",
      "jobTitle": "Enterprise AI Architect",
      "description": "Enterprise AI architect and agentic AI implementation specialist with 20+ years of experience deploying production AI systems in regulated industries. Expert in generative AI architecture, multi-agent orchestration, RAG pipelines, Azure OpenAI, Semantic Kernel, and AI-driven SDLC transformation.",
      "knowsAbout": [
        "Enterprise AI Implementation",
        "Agentic AI Architecture",
        "Generative AI Architecture",
        "Multi-Agent Orchestration",
        "RAG Pipeline Design",
        "Azure OpenAI",
        "Semantic Kernel",
        "Microsoft Copilot Studio",
        "LLM Orchestration",
        "AI Maturity Assessment",
        "AI-Driven SDLC Transformation",
        "Healthcare AI Architecture",
        "Financial Services AI",
        "Zero-Trust AI Security",
        "Dark Factory Design",
        "Python AI Pipeline Development",
        "LangChain",
        "LangFlow"
      ],
      "hasCredential": [
        {
          "@type": "EducationalOccupationalCredential",
          "name": "Microsoft Certified: Azure Solutions Architect Expert (AZ-305)",
          "credentialCategory": "Professional Certification"
        },
        {
          "@type": "EducationalOccupationalCredential",
          "name": "Microsoft LEAP Alumni",
          "credentialCategory": "Professional Program"
        }
      ],
      "hasOccupation": {
        "@type": "Occupation",
        "name": "Enterprise AI Architect",
        "occupationalCategory": "15-1299.09",
        "skills": "Agentic AI deployment, generative AI architecture, RAG pipeline design, multi-agent orchestration, enterprise AI implementation, AI maturity assessment, Azure OpenAI, Semantic Kernel, Microsoft Copilot Studio"
      },
      "sameAs": [
        "https://www.linkedin.com/in/wilfredmorgan/"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "info@wilfredmorgan.com",
        "contactType": "Business Inquiries",
        "url": "https://wilfredmorgan.com/contact"
      }
    })} />

    <!-- WebSite Schema (AEO) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Wilfred Morgan — Enterprise AI Architect",
      "url": "https://wilfredmorgan.com",
      "description": "Enterprise AI architecture consulting, agentic AI implementation, and thought leadership from Wilfred Morgan — production AI deployment for regulated industries.",
      "author": {
        "@type": "Person",
        "name": "Wilfred Morgan",
        "url": "https://wilfredmorgan.com"
      }
    })} />

    <!-- ProfessionalService Schema (AEO) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Wilfred Morgan — Enterprise AI Consulting",
      "url": "https://wilfredmorgan.com",
      "description": "Enterprise AI architecture consulting specializing in agentic AI implementation, RAG pipeline design, AI maturity assessment, and generative AI architecture for regulated industries.",
      "provider": {
        "@type": "Person",
        "name": "Wilfred Morgan"
      },
      "serviceType": [
        "AI Architecture Consulting",
        "Agentic AI Implementation",
        "RAG Pipeline Design",
        "AI Maturity Assessment",
        "Enterprise AI Governance"
      ],
      "areaServed": "Worldwide",
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "AI Consulting Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "AI Architecture Strategy Call",
              "description": "90-minute engagement for CTO, VP Engineering, and Head of AI to assess AI maturity and define implementation roadmap."
            }
          }
        ]
      }
    })} />

    <!-- Extra JSON-LD schemas -->
    {extraJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
</head>
  <body>
    <slot />
  </body>
</html>
