---
import "../styles/global.css";
import { SITE } from "../consts/index";
import sharedData from "../data/shared.json";
const { seo } = sharedData;

// Build JSON-LD schema objects from data layer
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": seo.personSchema.name,
  "url": seo.personSchema.url,
  "jobTitle": seo.personSchema.jobTitle,
  "description": seo.personSchema.description,
  "knowsAbout": seo.personSchema.knowsAbout,
  "hasCredential": seo.personSchema.credentials.map((c: { name: string; category: string }) => ({
    "@type": "EducationalOccupationalCredential",
    "name": c.name,
    "credentialCategory": c.category
  })),
  "hasOccupation": {
    "@type": "Occupation",
    "name": seo.personSchema.occupation.name,
    "occupationalCategory": seo.personSchema.occupation.category,
    "skills": seo.personSchema.occupation.skills
  },
  "sameAs": seo.personSchema.sameAs,
  "contactPoint": {
    "@type": "ContactPoint",
    "email": seo.personSchema.contactPoint.email,
    "contactType": seo.personSchema.contactPoint.contactType,
    "url": seo.personSchema.contactPoint.url
  }
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": seo.webSiteSchema.name,
  "url": seo.webSiteSchema.url,
  "description": seo.webSiteSchema.description,
  "author": {
    "@type": "Person",
    "name": seo.personSchema.name,
    "url": seo.personSchema.url
  }
};

const professionalServiceSchema = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": seo.professionalServiceSchema.name,
  "url": seo.professionalServiceSchema.url,
  "description": seo.professionalServiceSchema.description,
  "provider": {
    "@type": "Person",
    "name": seo.personSchema.name
  },
  "serviceType": seo.professionalServiceSchema.serviceTypes,
  "areaServed": seo.professionalServiceSchema.areaServed,
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "AI Consulting Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": seo.professionalServiceSchema.strategyCallOffer.name,
          "description": seo.professionalServiceSchema.strategyCallOffer.description
        }
      }
    ]
  }
};

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  ogType?: string;
  extraJsonLd?: Record<string, any>[];
}

const {
  title = SITE.title,
  description = SITE.description,
  ogImage = SITE.ogImage,
  noIndex = false,
  ogType = "website",
  extraJsonLd = [],
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {noIndex ? <meta name="robots" content="noindex,nofollow" /> : <meta name="robots" content="index,follow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <meta name="generator" content={Astro.generator} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!-- WebSite Schema (AEO) -->
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />

    <!-- ProfessionalService Schema (AEO) -->
    <script type="application/ld+json" set:html={JSON.stringify(professionalServiceSchema)} />

    <!-- Extra JSON-LD schemas -->
    {extraJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
</head>
  <body>
    <slot />
  </body>
</html>
