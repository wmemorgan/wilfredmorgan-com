---
// src/pages/contact/index.astro
// wilfredmorgan.com — Contact
// FINAL v1 — Calendly wired: https://calendly.com/wilfred-morgan/
// SDS Build: WM_ContactPage_2026-03-11_v1-final

import PageLayout from "../../layouts/PageLayout.astro";

const CALENDLY_URL = "https://calendly.com/wilfred-morgan/";
---

<PageLayout
  title="Contact — Wilfred Morgan"
  description="Book a strategy call with Wilfred Morgan — Principal Architect and AI systems engineer."
>
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">

      <!-- Page header -->
      <div class="grid lg:grid-cols-12 gap-8 mb-16">
        <div class="lg:col-span-3">
          <span class="section-label">Contact</span>
          <div class="mt-3 w-12 h-px bg-gold/40"></div>
        </div>
        <div class="lg:col-span-9">
          <h1
            class="font-heading font-800 text-slate-100 leading-tight mb-4"
            style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.03em;"
          >
            Book a Strategy Call
          </h1>
          <p class="font-body text-slate-400 max-w-xl" style="font-size: 1.0625rem; line-height: 1.75;">
            Calls are reserved for CTO, VP Engineering, and Head of AI at
            organizations ready to move from exploration to execution. Bring a
            real problem. Leave with a real plan.
          </p>
        </div>
      </div>

      <!-- Contact options -->
      <div class="grid lg:grid-cols-12 gap-8">
        <div class="lg:col-span-3"></div>
        <div class="lg:col-span-9">

          <!-- Option cards -->
          <div class="grid sm:grid-cols-2 gap-4 mb-12">
            {
              [
                {
                  type: "Strategy Call",
                  desc: "90-minute architecture engagement. CTO / VP Engineering / Head of AI. Limited availability. Engagement terms discussed on inquiry.",
                  cta: "Schedule on Calendly",
                  href: CALENDLY_URL,
                  external: true,
                  primary: true,
                },
                {
                  type: "Speaking & Consulting Inquiries",
                  desc: "Conferences, keynotes, panels, and paid consulting engagements. Autonomous systems · AI transformation · Dark Factory methodology.",
                  cta: "Send inquiry",
                  href: "mailto:info@wilfredmorgan.com",
                  external: false,
                  primary: false,
                },
              ].map((option) => (
                <div
                  class:list={[
                    "p-8 border transition-all duration-200",
                    option.primary
                      ? "border-gold/30"
                      : "border-white/5 hover:border-gold/15",
                  ]}
                  style={option.primary ? "background: linear-gradient(135deg, rgba(212,175,55,0.04) 0%, transparent 100%);" : ""}
                >
                  {option.primary && (
                    <div class="mb-4">
                      <span class="font-mono text-xs text-gold/70 tracking-widest border border-gold/30 px-2 py-0.5">
                        PRIMARY
                      </span>
                    </div>
                  )}
                  <h2 class="font-heading font-700 text-slate-100 text-lg mb-3">
                    {option.type}
                  </h2>
                  <p class="font-body text-slate-400 text-sm leading-relaxed mb-6">
                    {option.desc}
                  </p>
                  <a
                    href={option.href}
                    target={option.external ? "_blank" : undefined}
                    rel={option.external ? "noopener noreferrer" : undefined}
                    class:list={[option.primary ? "btn-gold text-sm" : "btn-ghost text-sm"]}
                  >
                    {option.cta} →
                  </a>
                </div>
              ))
            }
          </div>

          <!-- Calendly embed -->
          <div
            class="border border-gold/15 overflow-hidden"
            style="min-height: 700px;"
          >
            <!-- Calendly inline widget -->
            <div
              class="calendly-inline-widget w-full"
              data-url={`${CALENDLY_URL}?hide_gdpr_banner=1&background_color=0f172a&text_color=f1f5f9&primary_color=d4af37`}
              style="min-width: 320px; height: 700px;"
            ></div>
          </div>

          <!-- Qualifier note -->
          <div class="mt-8 border border-white/5 p-6">
            <h3 class="font-heading font-600 text-slate-300 text-sm mb-3">
              Who this call is for
            </h3>
            <div class="grid sm:grid-cols-2 gap-4">
              {
                [
                  "CTO or VP Engineering at an F500 or high-growth company",
                  "Head of AI at an organization past the pilot stage",
                  "Leaders with a real transformation problem — not an exploration budget",
                  "Organizations ready to act on a 90-day plan",
                ].map((item) => (
                  <div class="flex items-start gap-2">
                    <span class="text-gold/50 mt-0.5 shrink-0">▸</span>
                    <span class="font-body text-slate-500 text-sm">{item}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<!-- Calendly widget script -->
<script
  is:inline
  src="https://assets.calendly.com/assets/external/widget.js"
  type="text/javascript"
  async
></script>
