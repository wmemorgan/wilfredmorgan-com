---
// src/pages/about/index.astro
// wilfredmorgan.com — About
// STATUS: Scaffolded with core content — Phase 2 final copy pass
// SDS Build: WM_AboutPage_2026-03-11_v1

import PageLayout from "../../layouts/PageLayout.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://wilfredmorgan.com" },
    { "@type": "ListItem", "position": 2, "name": "About", "item": "https://wilfredmorgan.com/about" }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How to transition from software engineer to AI architect?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most effective path from software engineer to AI architect combines three elements: deep platform expertise (Azure OpenAI, Semantic Kernel, or equivalent LLM orchestration frameworks), production deployment experience in governed enterprise environments, and strategic consulting skills to translate technical capabilities into business outcomes. The key differentiator is being a builder-strategist — someone who can architect complex AI solutions, prototype to prove value, and communicate the business case to executive leadership. Certifications like AZ-305 and AI-102 provide credibility, but hands-on production experience with agentic AI and RAG pipelines is what separates architects from theorists."
      }
    },
    {
      "@type": "Question",
      "name": "Does Wilfred Morgan do AI consulting and speaking engagements?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Wilfred Morgan is available for enterprise AI architecture consulting, AI maturity assessments, conference keynotes, and panel discussions on topics including agentic AI deployment, multi-agent orchestration, AI-driven SDLC transformation, and production AI systems in regulated industries. Engagements are selective and reserved for organizations ready to move from AI exploration to production execution."
      }
    },
    {
      "@type": "Question",
      "name": "What industries does Wilfred Morgan specialize in for AI implementation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Wilfred Morgan's AI architecture practice focuses on regulated industries including financial services (11+ years, including banking CIO experience), healthcare (document intelligence, conversational AI, HIPAA-compliant architectures), and energy/manufacturing (operational AI, workflow automation). The common thread is deploying production AI systems where security, compliance, and governance are non-negotiable — not optional."
      }
    }
  ]
};
---

<PageLayout
  title="About Wilfred Morgan — Enterprise AI Architect & AI Strategy Executive"
  description="Wilfred Morgan is an enterprise AI architect with 20+ years of experience deploying production AI systems in financial services, healthcare, and energy. Former banking CIO turned hands-on AI builder — Semantic Kernel, Azure OpenAI, multi-agent orchestration."
  extraJsonLd={[breadcrumbSchema, faqSchema]}
>
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">

      <!-- Page header -->
      <div class="grid lg:grid-cols-12 gap-8 mb-16">
        <div class="lg:col-span-3">
          <span class="section-label">About</span>
          <div class="mt-3 w-12 h-px bg-gold/40"></div>
        </div>
        <div class="lg:col-span-9">
          <h1 class="sr-only">
            Wilfred Morgan — Enterprise AI Architect, Generative AI Architecture & AI Strategy Executive
          </h1>
          <p
            class="font-heading font-extrabold text-slate-100 leading-tight mb-4"
            style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.03em;"
            aria-hidden="true"
          >
            The Architect
          </p>
        </div>
      </div>

      <!-- Bio content -->
      <div class="grid lg:grid-cols-12 gap-12">
        <div class="lg:col-span-3">
          <!-- Compact identity card -->
          <div class="sticky top-24 border border-gold/15 p-6">
            <div class="flex items-center justify-center w-16 h-16 border border-gold/30 mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120" class="w-12 h-12" aria-hidden="true">
                <path d="M 8 20 L 8 100 L 20 100 L 20 20 Z" fill="#D4AF37"/>
                <path d="M 20 100 L 30 48 L 40 100 Z" fill="#D4AF37"/>
                <path d="M 40 20 L 40 100 L 52 100 L 52 20 Z" fill="#D4AF37"/>
                <path d="M 60 20 L 60 100 L 72 100 L 72 20 Z" fill="#D4AF37"/>
                <path d="M 72 20 L 82 60 L 92 20 Z" fill="#D4AF37" opacity="0.5"/>
                <path d="M 92 20 L 92 100 L 104 100 L 104 20 Z" fill="#D4AF37"/>
              </svg>
            </div>
            <div class="space-y-3">
              {
                [
                  { label: "Role", value: "Enterprise AI Architect" },
                  { label: "Specialization", value: "Agentic AI · Generative AI · Multi-Agent Systems" },
                  { label: "Experience", value: "20+ years" },
                  { label: "Verticals", value: "Financial Services · Healthcare · Energy" },
                  { label: "Engagements", value: "Selective — inquiry only" },
                  { label: "Status", value: "Available for engagements" },
                ].map((item) => (
                  <div>
                    <div class="font-mono text-xs text-slate-400 tracking-wider">{item.label}</div>
                    <div class="font-body text-sm text-slate-300 mt-0.5">{item.value}</div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <!-- Main bio -->
        <div class="lg:col-span-9">
          <div class="prose-custom space-y-6 font-body text-slate-400" style="font-size: 1.0625rem; line-height: 1.8;">
            <p>
              I am a Principal Architect and AI systems engineer with over 15 years
              of experience designing and deploying enterprise-grade technology systems.
              I am not a manager who moved into AI strategy. I am a builder — someone
              who has been writing code, designing architectures, and shipping production
              systems throughout my entire career.
            </p>
            <p>
              My current focus is the architecture and deployment of
              <span class="text-slate-200 font-semibold">Dark Factories</span> — fully
              autonomous, AI-orchestrated operational pipelines that eliminate human
              operator touchpoints between task intake and artifact delivery. The
              Sovereign Council, my flagship project, is a live 13-agent system running
              across five operational domains as my primary business infrastructure.
            </p>
            <p>
              I work with CTO, VP Engineering, and Head of AI at F500 and high-growth
              organizations who are done with exploration and ready for execution. My
              advisory engagements are structured for organizations that have a real
              transformation problem and the organizational will to solve it in 90 days
              instead of 18 months.
            </p>
            <p>
              I am also available for speaking engagements, conference panels, and
              keynotes on autonomous systems design, AI transformation at enterprise
              scale, and the future of human-AI collaboration in technical organizations.
            </p>
          </div>

          <!-- Divider -->
          <div class="my-12 w-full h-px bg-gold/10"></div>

          <!-- Speaking section -->
          <div>
            <h2 class="font-heading font-bold text-slate-100 text-xl mb-6">
              Speaking & Panels
            </h2>
            <p class="font-body text-slate-400 mb-8" style="line-height: 1.75;">
              Available for conferences, panels, and keynotes on autonomous systems,
              AI transformation, and the architecture of Dark Factory operations.
              Target audiences: technology leadership, enterprise AI practitioners,
              innovation forums.
            </p>

            <div class="space-y-3">
              {
                [
                  { topic: "Dark Factory Architecture", desc: "How to design and deploy fully autonomous operational pipelines at enterprise scale." },
                  { topic: "AI Transformation That Actually Ships", desc: "The architectural decisions that separate successful AI transformations from expensive experiments." },
                  { topic: "The 90-Day Enterprise Transformation", desc: "Practical methodology for compressing 18-month roadmaps without compromising quality or security." },
                  { topic: "Multi-Agent System Design", desc: "Agent taxonomy, orchestration patterns, and failure mode management for production AI systems." },
                ].map((talk) => (
                  <div class="border border-white/5 hover:border-gold/15 p-5 transition-all duration-200">
                    <h3 class="font-heading font-semibold text-slate-200 text-sm mb-1">{talk.topic}</h3>
                    <p class="font-body text-slate-500 text-sm">{talk.desc}</p>
                  </div>
                ))
              }
            </div>

            <div class="mt-8">
              <a href="/contact" class="btn-ghost">
                Speaking Inquiry →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
