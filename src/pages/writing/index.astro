---
// src/pages/writing/index.astro
// wilfredmorgan.com — Writing / Thought Leadership
// FINAL v1 — Content Collections wired
// SDS Build: WM_WritingPage_2026-03-11_v1-final

import PageLayout from "../../layouts/PageLayout.astro";
import { getCollection } from "astro:content";

const allArticles = await getCollection("writing", ({ data }) => !data.draft);

// Sort by date descending
const articles = allArticles.sort((a, b) =>
  b.data.date.localeCompare(a.data.date)
);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://wilfredmorgan.com" },
    { "@type": "ListItem", "position": 2, "name": "Writing", "item": "https://wilfredmorgan.com/writing" }
  ]
};
---

<PageLayout
  title="Writing — Wilfred Morgan"
  description="Thought leadership on Dark Factory methodology, AI transformation, and autonomous systems design."
  extraJsonLd={[breadcrumbSchema]}
>
  <section class="py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">

      <!-- Page header -->
      <div class="grid lg:grid-cols-12 gap-8 mb-16">
        <div class="lg:col-span-3">
          <span class="section-label">Writing</span>
          <div class="mt-3 w-12 h-px bg-gold/40"></div>
        </div>
        <div class="lg:col-span-9">
          <h1
            class="font-heading font-800 text-slate-100 leading-tight mb-4"
            style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.03em;"
          >
            Thought Leadership
          </h1>
          <p class="font-body text-slate-400 max-w-xl" style="font-size: 1.0625rem; line-height: 1.75;">
            On Dark Factory methodology, AI transformation, and what it
            actually takes to build autonomous systems at enterprise scale.
          </p>
        </div>
      </div>

      <!-- Article list -->
      <div class="grid lg:grid-cols-12 gap-8">
        <div class="lg:col-span-3"></div>
        <div class="lg:col-span-9 space-y-px">
          {
            articles.map((article) => (
              <a
                href={`/writing/${article.slug}`}
                class="block group border border-white/5 hover:border-gold/20 p-8 transition-all duration-300"
              >
                <!-- Meta row -->
                <div class="flex items-center gap-3 mb-4">
                  <span class="font-mono text-xs text-gold/50 tracking-wider">
                    {article.data.date}
                  </span>
                  <span class="text-slate-700">·</span>
                  <span class="font-mono text-xs text-slate-600">
                    {article.data.readTime} read
                  </span>
                  <span class="text-slate-700">·</span>
                  <span class="font-mono text-xs text-slate-600 tracking-wider">
                    {article.data.category}
                  </span>
                </div>

                <!-- Title -->
                <h2 class="font-heading font-700 text-slate-100 text-lg leading-snug mb-3 group-hover:text-gold transition-colors duration-200">
                  {article.data.title}
                </h2>

                <!-- Excerpt -->
                <p class="font-body text-slate-500 text-sm leading-relaxed">
                  {article.data.excerpt}
                </p>

                <!-- Read more -->
                <div class="mt-5 flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                  <span class="font-mono text-xs text-gold/70 tracking-wider">
                    READ ARTICLE
                  </span>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path
                      d="M2 7h10M8 3l4 4-4 4"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-gold/70"
                    />
                  </svg>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</PageLayout>
