---
// src/pages/writing/[slug].astro
// wilfredmorgan.com — Article Detail Page
// SDS Build: WM_ArticleDetail_2026-03-11_v1-final

import PageLayout from "../../layouts/PageLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("writing", ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();
---

<PageLayout
  title={`${article.data.title} — Wilfred Morgan`}
  description={article.data.excerpt}
>
  <article class="py-24 lg:py-32">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">

      <!-- Article header -->
      <div class="grid lg:grid-cols-12 gap-8 mb-12">
        <div class="lg:col-span-3">
          <a
            href="/writing"
            class="inline-flex items-center gap-2 font-mono text-xs text-slate-500 hover:text-gold transition-colors duration-200 tracking-wider mb-6"
          >
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <path d="M12 7H2M6 3L2 7l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            WRITING
          </a>
          <div class="sticky top-24 space-y-4 mt-2">
            <div>
              <div class="font-mono text-xs text-slate-600 tracking-wider">Date</div>
              <div class="font-body text-sm text-slate-400 mt-0.5">{article.data.date}</div>
            </div>
            <div>
              <div class="font-mono text-xs text-slate-600 tracking-wider">Read time</div>
              <div class="font-body text-sm text-slate-400 mt-0.5">{article.data.readTime}</div>
            </div>
            <div>
              <div class="font-mono text-xs text-slate-600 tracking-wider">Category</div>
              <div class="font-body text-sm text-slate-400 mt-0.5">{article.data.category}</div>
            </div>
            <div class="pt-4 border-t border-white/5">
              <a href="/contact" class="btn-ghost text-xs py-2 px-4 block text-center">
                Book a Call →
              </a>
            </div>
          </div>
        </div>

        <!-- Article content -->
        <div class="lg:col-span-9">
          <h1
            class="font-heading font-800 text-slate-100 leading-tight mb-6"
            style="font-size: clamp(1.75rem, 3.5vw, 3rem); letter-spacing: -0.02em;"
          >
            {article.data.title}
          </h1>
          <p class="font-body text-slate-400 text-lg leading-relaxed mb-10 border-l-2 border-gold/30 pl-5 italic">
            {article.data.excerpt}
          </p>

          <!-- Divider -->
          <div class="w-full h-px bg-gold/10 mb-10"></div>

          <!-- Rendered markdown -->
          <div
            class="prose-wm font-body text-slate-400"
            style="
              --prose-body: #94a3b8;
              --prose-headings: #f1f5f9;
              --prose-gold: #d4af37;
              font-size: 1.0625rem;
              line-height: 1.85;
            "
          >
            <style>
              .prose-wm h2 {
                font-family: 'Public Sans', sans-serif;
                font-weight: 700;
                font-size: 1.35rem;
                color: #f1f5f9;
                margin-top: 2.5rem;
                margin-bottom: 1rem;
                letter-spacing: -0.01em;
              }
              .prose-wm h3 {
                font-family: 'Public Sans', sans-serif;
                font-weight: 600;
                font-size: 1.1rem;
                color: #e2e8f0;
                margin-top: 2rem;
                margin-bottom: 0.75rem;
              }
              .prose-wm p { margin-bottom: 1.25rem; }
              .prose-wm strong { color: #e2e8f0; font-weight: 600; }
              .prose-wm em { color: #94a3b8; }
              .prose-wm ul { margin: 1.25rem 0; padding-left: 0; list-style: none; }
              .prose-wm ul li {
                display: flex;
                gap: 0.75rem;
                margin-bottom: 0.6rem;
                color: #94a3b8;
              }
              .prose-wm ul li::before {
                content: '▸';
                color: rgba(212,175,55,0.5);
                flex-shrink: 0;
                margin-top: 0.1em;
              }
              .prose-wm ol { margin: 1.25rem 0; padding-left: 1.5rem; }
              .prose-wm ol li { margin-bottom: 0.6rem; color: #94a3b8; }
              .prose-wm a { color: #d4af37; text-decoration: none; border-bottom: 1px solid rgba(212,175,55,0.3); }
              .prose-wm a:hover { border-bottom-color: rgba(212,175,55,0.8); }
              .prose-wm code {
                font-family: 'JetBrains Mono', monospace;
                font-size: 0.85em;
                color: #38bdf8;
                background: rgba(56,189,248,0.08);
                padding: 0.15em 0.4em;
                border-radius: 2px;
              }
              .prose-wm blockquote {
                border-left: 2px solid rgba(212,175,55,0.4);
                padding-left: 1.25rem;
                margin: 1.5rem 0;
                color: #64748b;
                font-style: italic;
              }
            </style>
            <Content />
          </div>

          <!-- Article footer -->
          <div class="mt-16 pt-8 border-t border-gold/10">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
              <div>
                <p class="font-heading font-600 text-slate-200 text-sm mb-1">
                  Wilfred Morgan
                </p>
                <p class="font-mono text-xs text-slate-500 tracking-wider">
                  Principal Architect · AI Systems Engineer
                </p>
              </div>
              <a href="/contact" class="btn-gold text-sm">
                Book a Strategy Call →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </article>
</PageLayout>
