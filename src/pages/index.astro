---
// src/pages/index.astro
// wilfredmorgan.com — Home Page
// FULLY BUILT — Phase 1 Production Complete
// SDS Build: WM_HomePage_2026-03-11_v1

import PageLayout from "../layouts/PageLayout.astro";
import Hero from "../components/Hero.astro";
import AuthorityStatement from "../components/AuthorityStatement.astro";
import DarkFactoryProof from "../components/DarkFactoryProof.astro";
import TechStackMarquee from "../components/TechStackMarquee.astro";
import CTASection from "../components/CTASection.astro";
import homepageData from "../data/homepage.json";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": homepageData.faqSchema.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<PageLayout
  title={homepageData.meta.title}
  description={homepageData.meta.description}
  extraJsonLd={[faqSchema]}
>
  <Hero />
  <AuthorityStatement />
  <DarkFactoryProof />
  <TechStackMarquee />
  <CTASection />
</PageLayout>
