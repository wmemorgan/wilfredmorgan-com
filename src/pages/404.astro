---
// src/pages/404.astro
// wilfredmorgan.com — Custom 404
// SDS Build: WM_404_2026-03-11_v2

import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Page Not Found — Wilfred Morgan"
  description="This page doesn't exist. Navigate back to wilfredmorgan.com."
  noIndex={true}
>
  <section class="min-h-[80vh] flex items-center py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 w-full">
      <div class="grid lg:grid-cols-12 gap-8">
        <div class="lg:col-span-3">
          <span class="section-label">404</span>
          <div class="mt-3 w-12 h-px bg-gold/40"></div>
        </div>
        <div class="lg:col-span-9">
          <div class="font-mono text-xs text-gold tracking-widest mb-4">
            ERROR_404 · PAGE_NOT_FOUND
          </div>
          <h1
            class="font-heading font-extrabold text-slate-100 leading-tight mb-6"
            style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: -0.03em;"
          >
            This page doesn't exist.
          </h1>
          <p class="font-body text-slate-400 max-w-lg mb-10" style="font-size: 1.0625rem; line-height: 1.75;">
            Even autonomous systems have edge cases. Navigate back to something real.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/" class="btn-gold">Back to Home →</a>
            <a href="/work" class="btn-ghost">View Architecture Work</a>
          </div>

          <div class="mt-12 pt-8 border-t border-white/5 grid sm:grid-cols-3 gap-4">
            {[
              { label: "Work", href: "/work" },
              { label: "Writing", href: "/writing" },
              { label: "Contact", href: "/contact" },
            ].map((link) => (
              <a
                href={link.href}
                class="font-mono text-xs text-slate-500 hover:text-gold tracking-widest uppercase transition-colors duration-200"
              >
                → {link.label}
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
